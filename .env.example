# Portal Assistant (owner-only pilot, page-agent). OPTIONAL and INERT by
# default: leave these unset and the assistant loads nothing and makes no
# external calls. Set all three to enable it FOR OWNERS ONLY. The key is
# exposed to the browser (NEXT_PUBLIC_) — use a restricted / proxy key, never a
# privileged one — and on-screen content is sent to the model, so don't use it
# on restricted/sealed records. See docs/DEV-TOOLING.md.
NEXT_PUBLIC_PAGE_AGENT_MODEL=
NEXT_PUBLIC_PAGE_AGENT_BASE_URL=
NEXT_PUBLIC_PAGE_AGENT_API_KEY=

